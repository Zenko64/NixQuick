{
  "[nix]": {
    "editor.defaultFormatter": "jnoortheen.nix-ide"
  },
  "nix.enableLanguageServer": true,
  "nix.serverPath": "nixd",
  "nix.serverSettings": {
    "nixd": {
      "formatting": {
        "command": [
          "nixfmt"
        ]
      },

      // Change (...nixosConfigurations.<host>.options) to your host for autoCompletions to work!
      // Make sure that the Flake Evaluates Cleanly.
      "options": {
        // "nixos": {
        //   "expr": "(builtins.getFlake (builtins.toString ./.)).nixosConfigurations.<host>.options"
        // },
        // "home-manager": {
        //   "expr": "(builtins.getFlake (builtins.toString ./.)).nixosConfigurations.<host>.options.home-manager.users.<user>"
        // },
        "flake-parts": {
          "expr": "(builtins.getFlake (builtins.toString ./.)).debug.options"
        }
      }
    }
  }
}